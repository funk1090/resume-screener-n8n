      ],
      "id": "42f0feb8-ef70-43bd-b192-317cc99373cc",
      "name": "Extract Job Description"
    },
    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of items) {\n  const binaries = item.binary || {};\n\n  for (const key of Object.keys(binaries)) {\n\n    if (key.startsWith(\"Resume\")) {\n\n      output.push({\n        json: item.json,\n        binary: {\n          resume: binaries[key]\n        }\n      });\n\n    }\n\n  }\n}\n\nreturn output;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -384,
        176
      ],
      "id": "e556adf8-518c-4aa9-8bef-c2007bb0c772",
      "name": "Code: Split Resumes"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an HR screening assistant.\n\nEvaluate how well the candidate matches the job description.\n\nJob Description:\n{{ $json.job_description_text }}\n\nCandidate Resume:\n{{ $json.resume_text }}\n\nReturn ONLY valid JSON.\n\nOutput format:\n{\n  \"candidate_name\": \"\",\n  \"matching_skills\": [],\n  \"missing_skills\": [],\n  \"match_percentage\": number\n}\n\nRules:\n- Extract candidate_name from the resume.\n- matching_skills must include skills clearly present in the resume that match the job description.\n- missing_skills must include required skills from the job description that are not present in the resume.\n- match_percentage must be a realistic estimation between 0 and 100.\n- matching_skills and missing_skills must be arrays of strings only.\n- Do NOT include explanations or comments.\n- Do NOT include text before or after the JSON.\n- The output must be valid JSON and parseable using JSON.parse().\n",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        528,
        96
      ],
      "id": "9e3d957a-19cc-41e8-8dea-72f9587e39aa",
      "name": "AI Agent"
    },
