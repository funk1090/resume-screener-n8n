      "id": "d745fbc8-c248-4b5e-9a07-abe47c635492",
      "name": "Combine JD + Resumes"
    },
    {
      "parameters": {
        "jsCode": "const cleaned = [];\n\nfor (const item of items) {\n\n  let raw = item.json.output;\n\n  const start = raw.indexOf(\"{\");\n  const end = raw.lastIndexOf(\"}\");\n\n  if (start !== -1 && end !== -1) {\n\n    const jsonString = raw.substring(start, end + 1);\n\n    try {\n\n      let parsed = JSON.parse(jsonString);\n\n      // \u2b50 Recalcular recomendaci\u00f3n\n      if (parsed.match_percentage > 80) {\n        parsed.recommendation = \"Best Fit\";\n      } \n      else if (parsed.match_percentage >= 60) {\n        parsed.recommendation = \"Average Fit\";\n      } \n      else {\n        parsed.recommendation = \"Not Fit\";\n      }\n      parsed.matching_skills = parsed.matching_skills.join(\", \");\n      parsed.missing_skills = parsed.missing_skills.join(\", \");\n\n      cleaned.push({ json: parsed });\n\n    } catch (err) {\n\n      cleaned.push({\n        json: {\n          error: \"Invalid JSON\",\n          raw_output: raw\n        }\n      });\n\n    }\n  }\n}\n\nreturn cleaned;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        96
      ],
